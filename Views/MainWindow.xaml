<Window x:Class="VirtuaSwitcher.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:VirtuaSwitcher.ViewModels"
        Title="VirtuaSwitcher"
        Width="700" Height="480"
        MinWidth="560" MinHeight="380"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}"
        ResizeMode="CanResize">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="VirtuaSwitcher"
                       FontSize="22" FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}"/>
            <TextBlock Text="Manage and switch between display configuration presets."
                       FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"
                       Margin="0,2,0,0"/>
        </StackPanel>

        <!-- Main content: preset list + detail -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Preset list -->
            <Border Grid.Column="0" Style="{StaticResource Card}" Padding="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <ListBox Grid.Row="0"
                             ItemsSource="{Binding Presets}"
                             SelectedItem="{Binding SelectedPreset}"
                             BorderThickness="0"
                             Background="Transparent"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:PresetViewModel}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding Name}"
                                               FontSize="13"
                                               Padding="8,6"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"/>
                                    <Button Grid.Column="1"
                                            x:Name="DeleteBtn"
                                            Content="×"
                                            FontSize="14"
                                            Width="24" Height="24"
                                            Margin="2,0,4,0"
                                            VerticalAlignment="Center"
                                            Visibility="Hidden"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Foreground="{StaticResource TextSecondaryBrush}"
                                            Cursor="Hand"
                                            ToolTip="Delete preset"
                                            Command="{Binding DataContext.DeletePresetCommand,
                                                RelativeSource={RelativeSource AncestorType=ListBox}}"
                                            CommandParameter="{Binding}"/>
                                </Grid>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding IsMouseOver,
                                        RelativeSource={RelativeSource AncestorType=ListBoxItem}}"
                                        Value="True">
                                        <Setter TargetName="DeleteBtn" Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="Bd" Background="Transparent" CornerRadius="4">
                                                <ContentPresenter/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#E8F0FE"/>
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#F1F3F4"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>

                    <Button Grid.Row="1"
                            Content="+ New Preset"
                            Style="{StaticResource SecondaryButton}"
                            Command="{Binding AddPresetCommand}"
                            Margin="0,8,0,0"
                            HorizontalAlignment="Stretch"/>
                </Grid>
            </Border>

            <!-- Preset detail panel -->
            <Border Grid.Column="2" Style="{StaticResource Card}">
                <!-- No selection placeholder -->
                <Grid>
                    <TextBlock Text="Select a preset to edit, or create a new one."
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="13"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Visibility="{Binding SelectedPreset, Converter={StaticResource NullToVisibilityConverter}}"/>

                    <!-- Detail content (visible when preset selected) -->
                    <StackPanel DataContext="{Binding SelectedPreset}"
                                Visibility="{Binding DataContext.SelectedPreset,
                                    RelativeSource={RelativeSource AncestorType=Window},
                                    Converter={StaticResource NotNullToVisibilityConverter}}">

                        <!-- Name -->
                        <TextBlock Text="Preset Name" Style="{StaticResource FieldLabel}"/>
                        <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                 FontSize="14"
                                 Padding="8,6"
                                 Margin="0,0,0,16"
                                 BorderBrush="{StaticResource BorderBrush}"
                                 BorderThickness="1"
                                 LostFocus="NameBox_LostFocus"/>

                        <!-- Hotkey -->
                        <TextBlock Text="Hotkey" Style="{StaticResource FieldLabel}"/>
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="HotkeyBox"
                                     Grid.Column="0"
                                     IsReadOnly="True"
                                     Text="{Binding Hotkey, Mode=OneWay, Converter={StaticResource HotkeyToStringConverter}}"
                                     Padding="8,6"
                                     BorderBrush="{StaticResource BorderBrush}"
                                     BorderThickness="1"
                                     PreviewKeyDown="HotkeyBox_PreviewKeyDown"
                                     GotFocus="HotkeyBox_GotFocus"
                                     LostFocus="HotkeyBox_LostFocus"
                                     Tag="Click to record hotkey..."
                                     FontSize="13"/>
                            <Button Grid.Column="2"
                                    Content="Clear"
                                    Style="{StaticResource SecondaryButton}"
                                    Click="ClearHotkey_Click"/>
                        </Grid>

                        <!-- Display config -->
                        <TextBlock Text="Display Configuration" Style="{StaticResource FieldLabel}"/>
                        <Border Style="{StaticResource Card}"
                                Margin="0,0,0,8"
                                Background="{StaticResource BackgroundBrush}">
                            <StackPanel>
                                <TextBlock Text="No configuration captured."
                                           FontSize="12"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           Visibility="{Binding HasTopology, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>
                                <ItemsControl ItemsSource="{Binding DisplaySummaries}"
                                              Visibility="{Binding HasTopology, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}"
                                                       FontSize="12"
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       Margin="0,1"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <Button Content="Capture Current Display Config"
                                Style="{StaticResource SecondaryButton}"
                                Command="{Binding CaptureConfigCommand}"
                                HorizontalAlignment="Left"
                                Margin="0,0,0,16"/>

                        <!-- Action buttons -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="Apply Now"
                                    Style="{StaticResource PrimaryButton}"
                                    Command="{Binding DataContext.ApplyPresetCommand,
                                        RelativeSource={RelativeSource AncestorType=Window}}"
                                    CommandParameter="{Binding}"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- Startup toggle -->
        <CheckBox Grid.Row="2"
                  Content="Launch VirtuaSwitcher at Windows startup"
                  IsChecked="{Binding LaunchOnStartup}"
                  Margin="0,12,0,0"
                  FontSize="13"/>

        <!-- Status bar -->
        <TextBlock Grid.Row="3"
                   Text="{Binding StatusMessage}"
                   Style="{StaticResource StatusText}"
                   Margin="0,8,0,0"/>
    </Grid>
</Window>
